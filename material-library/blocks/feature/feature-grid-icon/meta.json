{
  "id": "feature-grid-icon",
  "name": "Feature — Icon Grid",
  "version": "1.0.0",
  "type": "block",
  "category": "feature",
  "tags": ["features", "grid", "icons", "svg", "gsap", "stagger"],
  "description": "Optional section title springs in, then feature cards stagger upward with GSAP (back.out). Each card shows a circular icon path, title, and description with subtle elevation.",
  "contextMatch": {
    "mood": ["professional", "modern", "clear", "confident"],
    "industry": ["saas", "product", "fintech", "devtools", "marketing"],
    "platform": ["youtube", "bilibili", "linkedin", "web"],
    "contentType": ["product-tour", "feature-lists", "landing", "explainers"]
  },
  "props": {
    "title": { "type": "string", "required": false },
    "features": { "type": "array", "required": true, "description": "Items with SVG path icon, title, description" },
    "columns": { "type": "number", "enum": [2, 3], "default": 2 },
    "backgroundColor": { "type": "color", "default": "#020617" },
    "textColor": { "type": "color", "default": "#E2E8F0" },
    "accentColor": { "type": "color", "default": "#818CF8" },
    "fontFamily": { "type": "string", "default": "Inter" }
  },
  "duration": { "minFrames": 150, "maxFrames": 360, "defaultFrames": 240 },
  "component": "./Component.tsx",
  "schemaFile": "./schema.ts",
  "dependencies": ["useGsapTimeline hook", "gsap"],
  "compatibleStyles": ["minimal-motion", "neon-grid", "editorial"],
  "compatibleTransitions": ["fade", "dissolve", "slide-up"],
  "createdAt": "2026-04-06",
  "source": "library-upgrade"
}
