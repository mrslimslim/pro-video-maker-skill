{
  "id": "content-bullet-stagger",
  "name": "Staggered Bullet Content",
  "version": "1.0.0",
  "type": "block",
  "category": "content",
  "tags": ["bullet-points", "stagger", "heading", "multi-layout", "body-text"],
  "description": "Content scene with heading, optional body text, and bullet points that reveal with stagger animation. Supports centered, left-aligned, and split layouts.",
  "contextMatch": {
    "mood": ["professional", "energetic", "calm", "modern"],
    "industry": ["tech", "saas", "education", "marketing", "finance", "health"],
    "platform": ["douyin", "tiktok", "reels", "youtube", "bilibili", "instagram", "xiaohongshu"],
    "contentType": ["tips", "features", "arguments", "explanations", "listicle"]
  },
  "props": {
    "heading": { "type": "string", "required": true, "description": "Section heading" },
    "body": { "type": "string", "required": false, "description": "Body paragraph text" },
    "bulletPoints": { "type": "string[]", "required": false, "description": "Array of bullet point strings" },
    "layout": { "type": "enum", "values": ["centered", "left-aligned", "split"], "default": "centered" },
    "backgroundColor": { "type": "color", "default": "#0F172A" },
    "textColor": { "type": "color", "default": "#F8FAFC" },
    "accentColor": { "type": "color", "default": "#6366F1" },
    "fontFamily": { "type": "string", "default": "Inter" }
  },
  "duration": { "minFrames": 120, "maxFrames": 240, "defaultFrames": 180 },
  "component": "./Component.tsx",
  "schemaFile": "./schema.ts",
  "compatibleStyles": ["kinetic-typography", "minimal-motion", "flat-explainer", "tutorial-step"],
  "compatibleTransitions": ["slide-up", "slide-left", "fade", "push"],
  "createdAt": "2026-04-06",
  "source": "seed"
}
