{
  "id": "content-timeline-vertical",
  "name": "Vertical Timeline",
  "version": "1.0.0",
  "type": "block",
  "category": "content",
  "tags": ["timeline", "vertical", "roadmap", "milestones", "process", "gsap", "svg"],
  "description": "Center vertical timeline with drawn stroke, alternating left/right nodes that pop in with stagger, and labels that fade in after each node.",
  "contextMatch": {
    "mood": ["professional", "calm", "modern", "trustworthy"],
    "industry": ["saas", "enterprise", "consulting", "education", "finance"],
    "platform": ["youtube", "bilibili", "linkedin", "instagram", "xiaohongshu"],
    "contentType": ["roadmap", "history", "process", "journey", "changelog"]
  },
  "props": {
    "title": { "type": "string", "required": false, "description": "Optional heading above the timeline" },
    "items": {
      "type": "array",
      "required": true,
      "description": "Timeline entries with label and description",
      "items": { "label": "string", "description": "string" }
    },
    "backgroundColor": { "type": "color", "default": "#020617" },
    "textColor": { "type": "color", "default": "#E2E8F0" },
    "accentColor": { "type": "color", "default": "#38BDF8" },
    "fontFamily": { "type": "string", "default": "Inter" }
  },
  "duration": { "minFrames": 60, "maxFrames": 180, "defaultFrames": 120 },
  "component": "./Component.tsx",
  "schemaFile": "./schema.ts",
  "dependencies": ["useGsapTimeline hook"],
  "compatibleStyles": ["all"],
  "compatibleTransitions": ["fade", "slide-up"],
  "createdAt": "2026-04-06",
  "source": "library-upgrade"
}
