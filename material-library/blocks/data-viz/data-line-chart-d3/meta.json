  },
  "props": {
    "title": { "type": "string", "required": false, "description": "Optional heading above the chart" },
    "data": {
      "type": "array",
      "required": true,
      "description": "Points: { x, y }[]"
    },
    "lineColor": { "type": "color", "default": "#6366F1" },
    "backgroundColor": { "type": "color", "default": "#0F172A" },
    "textColor": { "type": "color", "default": "#F8FAFC" },
    "fontFamily": { "type": "string", "default": "Inter" },
    "showDots": { "type": "boolean", "default": true, "description": "Show markers at each data point" }
