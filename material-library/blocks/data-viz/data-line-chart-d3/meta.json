{
  "id": "data-line-chart-d3",
  "name": "D3 Line Chart",
  "version": "1.0.0",
  "type": "block",
  "category": "data-viz",
  "tags": ["d3", "line-chart", "axes", "stroke-dash", "dots", "stagger", "data-visualization"],
  "description": "Line chart with D3 scales and axes, path drawn via stroke-dashoffset tied to animation progress, and optional data points that pop in with spring stagger after the line finishes.",
  "contextMatch": {
    "mood": ["professional", "informative", "data-driven"],
