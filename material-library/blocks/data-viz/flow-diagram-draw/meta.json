{
  "id": "flow-diagram-draw",
  "name": "Vivus Flow Diagram Draw",
  "version": "1.0.0",
  "type": "block",
  "category": "data-viz",
  "tags": ["vivus", "gsap", "flow", "diagram", "process", "pipeline", "architecture", "svg", "draw"],
  "description": "Flow diagram / process chart with SVG connector lines drawn by Vivus.js and step nodes popped in by GSAP. Each node has a label and optional icon. Ideal for how-it-works, architecture diagrams, and multi-step processes.",
  "contextMatch": {
    "mood": ["professional", "informative", "modern", "technical"],
    "industry": ["tech", "saas", "consulting", "education", "enterprise"],
    "platform": ["youtube", "bilibili", "linkedin", "instagram"],
    "contentType": ["process-flows", "how-it-works", "architecture", "pipeline", "workflow"]
  },
  "props": {
    "heading": { "type": "string", "required": false, "description": "Optional heading" },
    "steps": {
      "type": "array",
      "required": true,
      "description": "Array of { label: string, description?: string }"
    },
    "direction": { "type": "string", "default": "horizontal", "description": "horizontal or vertical layout" },
    "backgroundColor": { "type": "color", "default": "#0F172A" },
    "textColor": { "type": "color", "default": "#F8FAFC" },
    "accentColor": { "type": "color", "default": "#6366F1" },
    "lineColor": { "type": "color", "default": "#475569" },
    "fontFamily": { "type": "string", "default": "Inter" }
  },
  "duration": { "minFrames": 180, "maxFrames": 360, "defaultFrames": 240 },
  "component": "./Component.tsx",
  "schemaFile": "./schema.ts",
  "dependencies": ["useVivusAnimation hook", "useGsapTimeline hook", "vivus"],
  "compatibleStyles": ["infographic-motion", "flat-explainer", "wireframe-clean"],
  "compatibleTransitions": ["fade", "slide-up", "dissolve"],
  "createdAt": "2026-04-06",
  "source": "seed"
}
