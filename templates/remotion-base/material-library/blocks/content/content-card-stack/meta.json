{
  "id": "content-card-stack",
  "name": "3D Card Stack Fan",
  "version": "1.0.0",
  "type": "block",
  "category": "content",
  "tags": ["cards", "3d", "stack", "fan", "gsap", "stagger", "deck"],
  "description": "Stacked cards in perspective that fan out with staggered rotateZ and translateY. Strong for feature decks, step summaries, and layered messaging.",
  "contextMatch": {
    "mood": ["playful", "modern", "energetic", "professional"],
    "industry": ["saas", "product", "education", "marketing", "startup"],
    "platform": ["douyin", "tiktok", "reels", "youtube", "bilibili", "instagram", "xiaohongshu"],
    "contentType": ["features", "steps", "comparison", "highlights", "pitch"]
  },
  "props": {
    "title": { "type": "string", "required": true, "description": "Scene title above the card stack" },
    "cards": {
      "type": "array",
      "required": true,
      "description": "Card entries with title and body (1–6 items)",
      "items": { "title": "string", "body": "string" }
    },
    "backgroundColor": { "type": "color", "default": "#0B1220" },
    "textColor": { "type": "color", "default": "#F1F5F9" },
    "accentColor": { "type": "color", "default": "#818CF8" },
    "fontFamily": { "type": "string", "default": "Inter" }
  },
  "duration": { "minFrames": 60, "maxFrames": 180, "defaultFrames": 120 },
  "component": "./Component.tsx",
  "schemaFile": "./schema.ts",
  "dependencies": ["useGsapTimeline hook"],
  "compatibleStyles": ["all"],
  "compatibleTransitions": ["fade", "slide-up"],
  "createdAt": "2026-04-06",
  "source": "library-upgrade"
}
