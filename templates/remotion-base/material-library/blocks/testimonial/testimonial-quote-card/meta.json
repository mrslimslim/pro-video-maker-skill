{
  "id": "testimonial-quote-card",
  "name": "Testimonial — Quote Card",
  "version": "1.0.0",
  "type": "block",
  "category": "testimonial",
  "tags": ["testimonial", "quote", "glass", "stars", "avatar", "social-proof"],
  "description": "Glassmorphism quote card: spring slide-up, circular avatar reveal, quote fade, staggered gold star rating (GSAP), and author line last.",
  "contextMatch": {
    "mood": ["trustworthy", "elegant", "calm", "professional"],
    "industry": ["saas", "ecommerce", "wellness", "education", "finance"],
    "platform": ["youtube", "bilibili", "linkedin", "instagram", "xiaohongshu"],
    "contentType": ["testimonials", "social-proof", "case-study", "landing-style"]
  },
  "props": {
    "quote": { "type": "string", "required": true },
    "author": { "type": "string", "required": true },
    "role": { "type": "string", "required": false },
    "rating": { "type": "number", "default": 5 },
    "avatarColor": { "type": "color", "default": "#6366F1", "description": "Solid circle fill behind initials" },
    "backgroundColor": { "type": "color", "default": "#0F172A" },
    "textColor": { "type": "color", "default": "#F1F5F9" },
    "accentColor": { "type": "color", "default": "#38BDF8" },
    "fontFamily": { "type": "string", "default": "Inter" }
  },
  "duration": { "minFrames": 120, "maxFrames": 240, "defaultFrames": 180 },
  "component": "./Component.tsx",
  "schemaFile": "./schema.ts",
  "dependencies": ["useGsapTimeline hook", "gsap"],
  "compatibleStyles": ["editorial", "minimal-motion", "storytelling-flow"],
  "compatibleTransitions": ["fade", "dissolve", "crossfade"],
  "createdAt": "2026-04-06",
  "source": "library-upgrade"
}
