{
  "id": "svg-draw-reveal",
  "name": "SVG Draw Reveal",
  "version": "1.0.0",
  "type": "block",
  "category": "custom",
  "tags": ["vivus", "svg", "draw", "line-drawing", "reveal", "whiteboard", "hand-drawn"],
  "description": "SVG illustration or icon drawn with Vivus.js line-by-line stroke animation, followed by an optional fill fade-in. Ideal for logo reveals, whiteboard-style explanations, and hand-drawn aesthetics.",
  "contextMatch": {
    "mood": ["friendly", "artistic", "calm", "modern"],
    "industry": ["education", "creative", "wellness", "design", "branding"],
    "platform": ["youtube", "bilibili", "instagram", "xiaohongshu"],
    "contentType": ["explainer", "whiteboard", "logo-reveal", "hand-drawn", "illustration"]
  },
  "props": {
    "svgContent": { "type": "string", "required": true, "description": "SVG markup string (paths with stroke, no fill)" },
    "heading": { "type": "string", "required": false, "description": "Optional heading below SVG" },
    "showFill": { "type": "boolean", "default": true, "description": "Fade in fill color after draw completes" },
    "strokeColor": { "type": "color", "default": "#F8FAFC" },
    "fillColor": { "type": "color", "default": "#6366F1" },
    "backgroundColor": { "type": "color", "default": "#0F172A" },
    "textColor": { "type": "color", "default": "#F8FAFC" },
    "fontFamily": { "type": "string", "default": "Inter" },
    "drawDurationFrames": { "type": "number", "default": 60, "description": "Frames for the stroke draw" }
  },
  "duration": { "minFrames": 90, "maxFrames": 180, "defaultFrames": 120 },
  "component": "./Component.tsx",
  "schemaFile": "./schema.ts",
  "dependencies": ["useVivusAnimation hook", "vivus"],
  "compatibleStyles": ["whiteboard", "flat-explainer", "minimal-motion", "organic-flow"],
  "compatibleTransitions": ["fade", "dissolve"],
  "createdAt": "2026-04-06",
  "source": "seed"
}
