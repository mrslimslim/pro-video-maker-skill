{
  "name": "pro-video",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "studio": "remotion studio",
    "render": "remotion render src/index.ts VideoComposition out/video.mp4",
    "render:dsl": "remotion render src/index.ts DSLVideo out/dsl-video.mp4",
    "render:social": "remotion render src/index.ts VideoComposition out/video.mp4 --height 1920 --width 1080",
    "render:landscape": "remotion render src/index.ts VideoComposition out/video.mp4 --height 1080 --width 1920",
    "render:square": "remotion render src/index.ts VideoComposition out/video.mp4 --height 1080 --width 1080",
    "upgrade": "remotion upgrade"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.0",
    "@remotion/transitions": "^4.0.0",
    "@remotion/media-utils": "^4.0.0",
    "js-yaml": "^4.1.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "remotion": "^4.0.0",
    "zod": "4.3.6",
    "gsap": "^3.12.0",
    "vivus": "^0.4.6",
    "d3": "^7.9.0",
    "lucide-react": "^0.400.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^18.3.0",
    "@types/d3": "^7.4.0",
    "typescript": "^5.5.0"
  }
}
